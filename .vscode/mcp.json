{
  "inputs": [
    {
      "type": "promptString",
      "id": "semantic-scholar-api-key",
      "description": "Semantic Scholar API key (optional)",
      "password": true
    },
    {
      "type": "promptString",
      "id": "contact-email",
      "description": "Contact email used for Crossref and server identification"
    }
  ],
  "servers": {
    "academicPaperSearch": {
      "type": "stdio",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": [
        "-m",
        "academic_mcp_server.server"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYTHONUNBUFFERED": "1",
        "ACADEMIC_MCP_SEMANTIC_SCHOLAR_API_KEY": "${input:semantic-scholar-api-key}",
        "ACADEMIC_MCP_CONTACT_EMAIL": "${input:contact-email}"
      },
      "dev": {
        "watch": "${workspaceFolder}/src/**/*.py",
        "debug": true
      }
    }
  }
}